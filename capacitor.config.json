{
  "appId": "com.pellazgo.app",
  "appName": "Pellazgo",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": [
      "*.pellazgo.com",
      "*.base44.com",
      "fonts.googleapis.com",
      "fonts.gstatic.com"
    ]
  },
  "ios": {
    "contentInset": "automatic",
    "scrollEnabled": true,
    "backgroundColor": "#0f3320",
    "preferredContentMode": "mobile",
    "limitsNavigationsToAppBoundDomains": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0f3320",
      "iosSpinnerStyle": "small",
      "spinnerColor": "#B8902A",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f3320",
      "overlaysWebView": false
    }
  }
}